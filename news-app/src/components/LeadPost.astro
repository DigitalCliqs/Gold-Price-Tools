---
import type { CollectionEntry } from 'astro:content';
import { categoryTitle } from '../lib/categories';
interface Props { entry: CollectionEntry<'news'>; }
const { entry } = Astro.props;
const { data, id } = entry;
const date = data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<a class="mag-lead" href={`/news/${id}/`}>
  {data.image && <img src={data.image} alt={data.imageAlt} loading="lazy" />}
  <div class="mag-lead__body">
    <span class="mag-tag">{categoryTitle(data.category)}</span>
    <h3 class="mag-lead__title">{data.title}</h3>
    <p class="mag-lead__ex">{data.description}</p>
    <div class="mag-meta"><span>{date}</span><span class="dot">&middot;</span><span>{data.author}</span></div>
  </div>
</a>
