---
import type { CollectionEntry } from 'astro:content';
import { categoryTitle } from '../lib/categories';
interface Props { entry: CollectionEntry<'news'>; }
const { entry } = Astro.props;
const { data, id } = entry;
const date = data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
---
<a class="mag-card" href={`/news/${id}/`}>
  <div class="mag-card__imgwrap">
    {data.image && <img src={data.image} alt={data.imageAlt} loading="lazy" width="800" height="450" />}
    <span class="mag-tag">{categoryTitle(data.category)}</span>
  </div>
  <div class="mag-card__body">
    <h3 class="mag-card__title">{data.title}</h3>
    <p class="mag-card__ex">{data.description}</p>
    <div class="mag-meta"><span>{date}</span><span class="dot">&middot;</span><span>{data.author}</span></div>
  </div>
</a>
