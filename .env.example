# GoldPriceTools — local environment variables (TEMPLATE)
# -------------------------------------------------------------------
# Copy this file to ".env.local" and paste your real keys there.
# .env.local is gitignored, so your keys never get committed or pushed.
#
# Used by: scripts/fetch-news-image.js  (free-licence article images)
# -------------------------------------------------------------------

# Unsplash — get a free "Access Key":
#   https://unsplash.com/developers  →  New Application  →  Access Key
UNSPLASH_ACCESS_KEY=

# Pexels — get a free API key:
#   https://www.pexels.com/api/  →  Get Started  →  Your API Key
PEXELS_API_KEY=
